@@ -8,6 +8,8 @@
 
 #include <OpenMS/ML/PEPTDEEP/PeptDeepInput.h>
 #include <OpenMS/ML/PEPTDEEP/PeptDeepUtils.h>
+#include <OpenMS/ML/PEPTDEEP/PeptDeepModX.h>   // vendored patch P2: mod_x featurization
+#include <OpenMS/CHEMISTRY/AASequence.h>
 #include <OpenMS/CONCEPT/Exception.h>
 
 #include <algorithm>
@@ -149,5 +151,73 @@ namespace OpenMS
 
       return batch;
     }
+
+    // --- Modified-peptide variants (vendored patch P2) ---------------------------
+    // aa_indices come from the unmodified base sequences (so the existing
+    // validation/padding logic is reused unchanged); mod_x is then filled from
+    // each AASequence's modifications by fillPeptideModX (bit-parity validated
+    // against AlphaPeptDeep in odia-modx-test).
+
+    PeptDeepInputBatch PeptDeepInputBuilder::buildModifiedPeptideBatch(
+      const std::vector<AASequence>& peptides,
+      const PeptDeepInputConfig& config)
+    {
+      if (peptides.empty())
+      {
+        throw Exception::IllegalArgument(__FILE__, __LINE__, OPENMS_PRETTY_FUNCTION, "Peptide batch cannot be empty.");
+      }
+      std::vector<std::string> base;
+      base.reserve(peptides.size());
+      for (const AASequence& seq : peptides) base.push_back(seq.toUnmodifiedString());
+
+      PeptDeepInputBatch batch = buildUnmodifiedPeptideBatch(base, config); // aa_indices + zero mod_x
+
+      const size_t E = static_cast<size_t>(PEPTDEEP_MOD_ELEMENTS);
+      for (size_t i = 0; i < peptides.size(); ++i)
+      {
+        float* slice = batch.mod_x.data() + i * batch.sequence_length * E;
+        fillPeptideModX(peptides[i], config.add_terminal_tokens, batch.sequence_length, slice);
+      }
+      return batch;
+    }
+
+    PeptDeepInputBatch PeptDeepInputBuilder::buildModifiedChargedBatch(
+      const std::vector<AASequence>& peptides,
+      const std::vector<float>& charges,
+      const PeptDeepInputConfig& config)
+    {
+      if (charges.size() != peptides.size())
+      {
+        throw Exception::IllegalArgument(__FILE__, __LINE__, OPENMS_PRETTY_FUNCTION,
+          "Peptide and charge input vectors must have the same size.");
+      }
+      PeptDeepInputBatch batch = buildModifiedPeptideBatch(peptides, config);
+      batch.charges.reserve(peptides.size());
+      for (float c : charges) batch.charges.push_back(c * CHARGE_SCALE);
+      return batch;
+    }
+
+    PeptDeepInputBatch PeptDeepInputBuilder::buildModifiedInstrumentBatch(
+      const std::vector<AASequence>& peptides,
+      const std::vector<float>& charges,
+      const std::vector<float>& nces,
+      const std::vector<int64_t>& instrument_indices,
+      const PeptDeepInputConfig& config)
+    {
+      if (charges.size() != peptides.size() || nces.size() != peptides.size() || instrument_indices.size() != peptides.size())
+      {
+        throw Exception::IllegalArgument(__FILE__, __LINE__, OPENMS_PRETTY_FUNCTION,
+          "Peptide, charge, NCE, and instrument input vectors must have the same size.");
+      }
+      PeptDeepInputBatch batch = buildModifiedChargedBatch(peptides, charges, config);
+      batch.nces.reserve(peptides.size());
+      batch.instrument_indices.reserve(peptides.size());
+      for (size_t i = 0; i < peptides.size(); ++i)
+      {
+        batch.nces.push_back(nces[i] * NCE_SCALE);
+        batch.instrument_indices.push_back(instrument_indices[i]);
+      }
+      return batch;
+    }
   } // namespace ML
 } // namespace OpenMS
